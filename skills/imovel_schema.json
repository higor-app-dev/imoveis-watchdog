{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchdog.imoveis/schemas/imovel-v1.json",
  "title": "Imóvel — Schema Unificado de Listagem",
  "description": "Schema unificado para listagens de imóveis de portais brasileiros (Loft, EmCasa, QuintoAndar, OLX, Zap, Lello). Normaliza campos de todos os portais em uma estrutura comum.",
  "type": "object",
  "required": ["codigo", "fonte", "negociacao"],
  "properties": {
    "codigo": {
      "type": "string",
      "description": "Código único do anúncio na fonte (ex.: list_id do OLX, objectID do Loft)."
    },
    "titulo": {
      "type": "string",
      "description": "Título do anúncio."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "URL direta do anúncio na fonte."
    },
    "fonte": {
      "type": "string",
      "description": "Nome da fonte/origem: 'loft', 'emcasa', 'quintoandar', 'olx', 'zap', 'lello'.",
      "examples": ["loft", "emcasa", "quintoandar", "olx", "zap"]
    },
    "negociacao": {
      "type": "string",
      "enum": ["venda", "aluguel"],
      "description": "Tipo de negociação: venda ou aluguel. Inferido dos campos de preço."
    },
    "tipo": {
      "type": "string",
      "description": "Tipo do imóvel. Valores comuns: apartamento, casa, cobertura, kitnet, studio, flat, loft, sobrado, terreno, comercial, casa_condominio.",
      "examples": ["apartamento", "casa", "cobertura", "kitnet", "studio", "flat", "loft", "sobrado", "terreno", "comercial"]
    },
    "preco": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Preço da negociação em R$ (venda ou aluguel, conforme negociacao)."
    },
    "preco_venda": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0,
      "description": "Preço de venda em R$. null se não estiver à venda."
    },
    "preco_aluguel": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0,
      "description": "Preço de aluguel em R$. null se não estiver para alugar."
    },
    "preco_anterior": {
      "type": ["number", "null"],
      "description": "Preço anterior (se houve redução). null se não informado."
    },
    "condominio": {
      "type": ["number", "null"],
      "description": "Taxa de condomínio em R$. null se não informado ou não aplicável."
    },
    "iptu": {
      "type": ["number", "null"],
      "description": "Valor do IPTU em R$. null se não informado."
    },
    "endereco": {
      "type": "string",
      "description": "Endereço completo (logradouro + número), se disponível."
    },
    "bairro": {
      "type": "string",
      "description": "Bairro do imóvel."
    },
    "cidade": {
      "type": "string",
      "description": "Cidade do imóvel."
    },
    "uf": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2,
      "description": "Sigla do estado (SP, RJ, MG, etc.)."
    },
    "cep": {
      "type": ["string", "null"],
      "description": "CEP do imóvel, se disponível."
    },
    "latitude": {
      "type": ["number", "null"],
      "description": "Latitude da localização do imóvel."
    },
    "longitude": {
      "type": ["number", "null"],
      "description": "Longitude da localização do imóvel."
    },
    "area": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0,
      "description": "Área útil em m²."
    },
    "quartos": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Número de quartos."
    },
    "suites": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Número de suítes."
    },
    "banheiros": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Número de banheiros."
    },
    "vagas": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Número de vagas de garagem."
    },
    "andar": {
      "type": ["integer", "null"],
      "description": "Andar do imóvel (se aplicável)."
    },
    "uso": {
      "type": "string",
      "description": "Tipo de uso: 'residential' ou 'commercial'.",
      "default": "residential"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição textual do anúncio."
    },
    "comodidades": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Lista de amenities/itens de lazer do imóvel ou condomínio."
    },
    "fotos": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "URLs das fotos do anúncio."
    },
    "agencia": {
      "type": "string",
      "description": "Nome da agência/imobiliária responsável."
    },
    "tem_reducao": {
      "type": "boolean",
      "description": "True se o imóvel teve redução de preço."
    },
    "percentual_reducao": {
      "type": "number",
      "description": "Percentual de redução de preço (se houver)."
    },
    "disponivel": {
      "type": "boolean",
      "default": true,
      "description": "True se o anúncio está ativo/disponível."
    },
    "data_coleta": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 de quando os dados foram coletados."
    },
    "data_publicacao": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp ISO 8601 de publicação do anúncio, se informado."
    },
    "data_atualizacao_preco": {
      "type": ["string", "null"],
      "description": "Timestamp ISO 8601 da última atualização de preço."
    },
    "origem_id": {
      "type": ["string", "null"],
      "description": "ID original do imóvel na fonte (ex.: unitId na Loft)."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "negociacao": { "const": "venda" } }
      },
      "then": {
        "required": ["preco_venda"],
        "properties": {
          "preco": { "minimum": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "negociacao": { "const": "aluguel" } }
      },
      "then": {
        "required": ["preco_aluguel"],
        "properties": {
          "preco": { "minimum": 0 }
        }
      }
    }
  ]
}
